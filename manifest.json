{
  "name": "matrix³",
  "version": "1.0.0",
  "manifest_version": 3,
  "description": "Minimal Content Security Policy Manager",
  "icons": {
      "32": "matrix3_32.png",
      "64": "matrix3_64.png"
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "matrix³"
  },
  "side_panel": {
    "default_path": "panels/report.html"
  },
  "options_ui": {
    "page": "panels/options.html",
    "open_in_tab": true
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "base",
        "enabled": true,
        "path": "base.json"
      }, {
        "id": "permissive",
        "enabled": false,
        "path": "permissive.json"
      }, {
        "id": "firstparty",
        "enabled": true,
        "path": "firstparty.json"
      }, {
        "id": "sandbox",
        "enabled": false,
        "path": "sandbox.json"
      }, {
        "id": "strict",
        "enabled": false,
        "path": "strict.json"
      }
    ]
  },
  "permissions": [
    "webNavigation",
    "webRequest",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "tabs",
    "sidePanel",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": [ "csp-report" ],
      "matches": [ "<all_urls>" ]
    }
  ]
}
